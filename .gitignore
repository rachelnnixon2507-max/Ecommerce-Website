# =============================================================
# Rachel's Store - .gitignore
# =============================================================

# =============================================================
# ASP.NET CORE / .NET
# =============================================================

# Build output
**/bin/
**/obj/

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Rider / JetBrains
.idea/
*.iml

# Publish output
**/publish/
**/out/

# NuGet
*.nupkg
packages/

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# =============================================================
# APP SETTINGS / SECRETS
# =============================================================

Backend/appsettings.json
Backend/appsettings.Production.json

# Optional: ignore if it contains secrets
# Backend/appsettings.Development.json

# User Secrets
**/secrets.json
**/*.secrets.json

# Certificates / Keys
*.pem
*.key
*.pfx
*.p12
*.crt
*.cer
*.cert
*.keystore

# =============================================================
# NODE / REACT / VITE
# =============================================================

node_modules/
frontend/node_modules/

dist/
frontend/dist/

.vite/
frontend/.vite/

.eslintcache

# Environment variables
.env
.env.*
frontend/.env
frontend/.env.*
!.env.example

# =============================================================
# LOGS
# =============================================================

logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# =============================================================
# OS FILES
# =============================================================

.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

Thumbs.db
Desktop.ini

# =============================================================
# VS CODE
# =============================================================

.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json

# =============================================================
# DATA PROTECTION
# =============================================================

Backend/DataProtection-Keys/

# =============================================================
# DOCKER
# =============================================================

docker-compose.override.yml

# =============================================================
# SQL SCRIPTS (optional)
# =============================================================

*.bak
